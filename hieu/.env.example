TEACHER_BASE_URL=http://192.168.50.218:8000/api/v1
LLM_BASE_URL=http://192.168.50.218:8000/api/v1/proxy
STUDENT_ID=B22XXXXXXX
STUDENT_SERVER_URL=http://<IP-LAN-cua-may>:5004
HOST=0.0.0.0
PORT=5004

# Teacher doi toi da 60s/cau -> (LLM_RETRIES+1) * LLM_TIMEOUT phai < 60
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=25
LLM_RETRIES=1

# Embedding bat buoc theo spec
RETRIEVER_BACKEND=hybrid
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
DEVICE=cpu

# Hybrid retrieval
VECTOR_CANDIDATES=30
BM25_WEIGHT=0.6
# weighted hoac rrf
HYBRID_FUSION=weighted
RRF_K=60
RETRIEVAL_INCLUDE_OPTIONS=false

# Prompt + postprocess
PROMPT_MODE=evidence
OPTION_SCORE_THRESHOLD=6.0
OPTION_SCORE_MARGIN=1.5
OVERRIDE_WITH_HEURISTIC=false

# Chunking + context khit cua so ~4k token cua LLM yeu
CHUNK_SIZE=700
CHUNK_OVERLAP=120
MIN_CHUNK_LEN=40
TOP_K=8
CONTEXT_TOP_K=4
MAX_CONTEXT_CHARS=2800
# Bo chunk gan trung lap khi retrieve (>=1.0 de tat)
DEDUP_THRESHOLD=0.92

# Persist VectorDB + answer cache
ENABLE_PERSIST=true
PERSIST_DIR=vectordb
ENABLE_ANSWER_CACHE=true
CACHE_DIR=cache

# Reranker tuy chon (de trong = nhanh hon). Vd: BAAI/bge-reranker-v2-m3
RERANKER_MODEL=
RERANK_CANDIDATES=20
RERANKER_BATCH_SIZE=4
RERANKER_MAX_LENGTH=512
