TEACHER_BASE_URL=http://192.168.50.218:8000/api/v1
LLM_BASE_URL=http://192.168.50.218:8000/api/v1/proxy
STUDENT_ID=B22XXXXXXX
STUDENT_SERVER_URL=http://<IP-LAN-cua-may>:5004
HOST=0.0.0.0
PORT=5004

LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=45

# Mac dinh an toan va nhe CPU hon cho private: bm25.
# Neu da tai model truoc va muon bat hybrid, doi thanh hybrid.
RETRIEVER_BACKEND=bm25
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
DEVICE=cpu

# Hybrid retrieval
VECTOR_CANDIDATES=36
BM25_WEIGHT=0.55
HYBRID_FUSION=weighted
RRF_K=60
RETRIEVAL_INCLUDE_OPTIONS=false

# Chunking + context khit cua so ~4k token cua LLM
CHUNK_SIZE=820
CHUNK_OVERLAP=140
TOP_K=10
CONTEXT_TOP_K=5
MAX_CONTEXT_CHARS=3400

# Prompt + postprocess
PROMPT_MODE=evidence
OPTION_SCORE_THRESHOLD=6.0
OPTION_SCORE_MARGIN=1.5
OVERRIDE_WITH_HEURISTIC=false

# Persist VectorDB
ENABLE_PERSIST=true
PERSIST_DIR=vectordb
ENABLE_ANSWER_CACHE=true
CACHE_DIR=cache

# Reranker tuy chon (de trong = nhanh hon). Vd: BAAI/bge-reranker-v2-m3
RERANKER_MODEL=
RERANK_CANDIDATES=20
RERANKER_BATCH_SIZE=4
RERANKER_MAX_LENGTH=512
